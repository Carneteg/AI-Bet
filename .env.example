# Required — GPT-4o vision API key for the image upload feature
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required — password to access the site
SITE_PASSWORD=your-password-here

# Required — secret token stored in the auth cookie (generate with: openssl rand -hex 32)
AUTH_SECRET=your-random-secret-here
