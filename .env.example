# Required — GPT-4o vision API key for image upload + live match analysis
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required — live match data from football-data.org
# Free tier at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-key-here

# Required — password to access the site
SITE_PASSWORD=your-password-here

# Required — secret token stored in the auth cookie (generate: openssl rand -hex 32)
AUTH_SECRET=your-random-secret-here
